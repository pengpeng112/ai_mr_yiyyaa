    {
      "code": "progress_vs_nursing",
      "name": "病程 vs 护理",
      "description": "病程记录与护理记录一致性核查",
      "enabled": true,
      "sort_order": 10,
      "default_for_schedule": true,
      "sources": {
        "primary": {
          "type": "sql",
          "query_sql": "WITH progress AS (\n  SELECT\n      a.??ID,\n      a.??,\n      a.???,\n      a.????,\n      a.??,\n      a.????,\n      a.????,\n      a.BED_NO AS ??,\n      a.????,\n      a.????,\n      a.???? AS ??????,\n      a.??????,\n      a.????,\n      b.?????? AS ????_????,\n      b.???? AS ????_??,\n      b.??? AS ????_????,\n      b.???? AS ????_??\n  FROM jhemr.v_zybr a\n  JOIN jhemr.v_bcjl b\n    ON a.??ID = b.??ID\n   AND a.?? = b.??\n  WHERE {dept_filter}\n    AND b.?????? >= TO_DATE(:query_date, 'yyyy-mm-dd')\n    AND b.?????? < TO_DATE(:query_date, 'yyyy-mm-dd') + 1\n),\nprogress_pat AS (\n  SELECT DISTINCT\n      ??ID,\n      ??\n  FROM progress\n),\nactive_pat AS (\n  SELECT /*+ MATERIALIZE INDEX(d IDX_INPATIENTS_01) */\n      p.??ID,\n      p.??,\n      d.pat_index_no\n  FROM progress_pat p\n  JOIN ydhl.inpatients d\n    ON d.patient_id = p.??ID || '_' || p.??\n),\nvalid_form AS (\n  SELECT /*+ MATERIALIZE LEADING(p f) USE_NL(f) INDEX(f IDX_MCS_DOC_FORM_01) */\n      p.??ID,\n      p.??,\n      f.id AS form_id,\n      f.patient_uid,\n      f.bed_no,\n      f.form_time,\n      f.created_name,\n      f.created_date\n  FROM active_pat p\n  JOIN ydhl.mcs_doc_form f\n    ON f.patient_uid = p.pat_index_no\n  WHERE f.is_valid = '1'\n    AND f.form_time >= TO_DATE(:query_date, 'yyyy-mm-dd')\n    AND f.form_time < TO_DATE(:query_date, 'yyyy-mm-dd') + 1\n),\nnursing_base AS (\n  SELECT /*+ LEADING(f r n) USE_NL(r) INDEX(r IDX_MCS_DOC_FORM_RECORDS_01) USE_NL(n) */\n      f.??ID,\n      f.??,\n      f.form_id,\n      f.form_time,\n      f.created_name,\n      f.created_date,\n      r.template_code,\n      r.node_code,\n      CASE\n        WHEN r.string_value IS NOT NULL THEN r.string_value\n        WHEN r.number_value = 1 THEN NVL(n.display_name, n.name)\n        WHEN r.number_value IS NOT NULL THEN TRIM(TO_CHAR(r.number_value, 'FM99999999990.099'))\n      END AS value,\n      ROW_NUMBER() OVER (\n        PARTITION BY f.form_id, r.node_code\n        ORDER BY n.id\n      ) AS rn\n  FROM valid_form f\n  JOIN ydhl.mcs_doc_form_records r\n    ON r.form_id = f.form_id\n   AND r.template_code IN ('572','709')\n   AND r.node_code IN (\n      '00172','00174','00122','00120','00093','00094',\n      '00022','00023','00024','00029','00153','00062'\n   )\n   AND (r.string_value IS NOT NULL OR r.number_value IS NOT NULL)\n  LEFT JOIN ydhl.mcs_doc_nodes n\n    ON n.template_code = r.template_code\n   AND n.code = r.node_code\n),\nnursing AS (\n  SELECT\n      ??ID,\n      ??,\n      form_id,\n      created_date AS ????_????,\n      CASE template_code\n        WHEN '572' THEN '?????????'\n        WHEN '709' THEN '????????????'\n        ELSE '??'\n      END AS ????_????,\n      created_name AS ????_???,\n      COALESCE(\n        MAX(CASE WHEN template_code = '572' AND node_code = '00093' THEN value END),\n        MAX(CASE WHEN template_code = '709' AND node_code = '00153' THEN value END)\n      ) AS ????_??,\n      COALESCE(\n        MAX(CASE WHEN template_code = '572' AND node_code = '00172' THEN value END),\n        MAX(CASE WHEN template_code = '709' AND node_code = '00022' THEN value END)\n      ) AS ????_??,\n      COALESCE(\n        MAX(CASE WHEN template_code = '572' AND node_code = '00174' THEN value END),\n        MAX(CASE WHEN template_code = '709' AND node_code = '00023' THEN value END)\n      ) AS ????_????,\n      COALESCE(\n        MAX(CASE WHEN template_code = '572' AND node_code = '00122' THEN value END),\n        MAX(CASE WHEN template_code = '709' AND node_code = '00024' THEN value END)\n      ) AS ????_??,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??,\n      COALESCE(\n        MAX(CASE WHEN template_code = '572' AND node_code = '00120' THEN value END),\n        MAX(CASE WHEN template_code = '709' AND node_code = '00029' THEN value END)\n      ) AS ????_?????,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??,\n      CAST(NULL AS VARCHAR2(100)) AS ????_????,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??_???,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??_??,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??_??,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??_??,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??_?,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??_??,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??_?,\n      CAST(NULL AS VARCHAR2(100)) AS ????_??,\n      CAST(NULL AS VARCHAR2(100)) AS ????_????,\n      CAST(NULL AS VARCHAR2(100)) AS ????_????,\n      CAST(NULL AS VARCHAR2(100)) AS ????_????,\n      CAST(NULL AS VARCHAR2(100)) AS ????_????,\n      COALESCE(\n        MAX(CASE WHEN template_code = '572' AND node_code = '00094' THEN value END),\n        MAX(CASE WHEN template_code = '709' AND node_code = '00062' THEN value END)\n      ) AS ????_????\n  FROM nursing_base\n  WHERE rn = 1\n  GROUP BY\n      ??ID,\n      ??,\n      form_id,\n      created_date,\n      created_name,\n      template_code\n)\nSELECT\n    p.??ID,\n    p.??,\n    p.???,\n    p.????,\n    p.??,\n    p.????,\n    p.????,\n    p.??,\n    p.????,\n    p.????,\n    p.??????,\n    p.??????,\n    p.????,\n    p.????_????,\n    p.????_??,\n    p.????_????,\n    p.????_??,\n    n.????_????,\n    n.????_????,\n    n.????_??,\n    n.????_???,\n    n.????_??,\n    n.????_????,\n    n.????_??,\n    n.????_??,\n    n.????_?????,\n    n.????_??,\n    n.????_????,\n    n.????_??_???,\n    n.????_??_??,\n    n.????_??_??,\n    n.????_??_??,\n    n.????_??_?,\n    n.????_??_??,\n    n.????_??_?,\n    n.????_??,\n    n.????_????,\n    n.????_????,\n    n.????_????,\n    n.????_????,\n    n.????_????\nFROM progress p\nLEFT JOIN nursing n\n  ON n.??ID = p.??ID\n AND n.?? = p.??\nORDER BY p.??ID, p.??, p.????_????, n.????_????",
          "field_mapping": {
            "patient_id": "患者ID",
            "visit_number": "次数",
            "patient_name": "患者姓名",
            "dept": "所在科室名称",
