        "progress": {
          "type": "sql",
          "query_sql": "SELECT b.患者ID, b.次数, b.病历标题时间 AS 病程时间, b.病历名称 AS 病历名称, b.病历内容 AS 病历内容 FROM jhemr.bcjl202603 b WHERE {dept_filter} AND TO_CHAR(b.病历标题时间, 'yyyy-mm-dd') = :query_date",
