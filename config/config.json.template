    {
      "code": "lab_exam_vs_progress_nursing",
      "name": "检验检查 vs 病程护理",
      "description": "检验/检查异常与病程、护理记录一致性核查",
      "enabled": false,
      "sort_order": 20,
      "default_for_schedule": false,
      "sources": {
        "lab": {
          "type": "sql",
          "query_sql": "SELECT m.PATIENT_ID AS 患者ID, m.VISIT_NUMBER AS 次数, m.TEST_NO AS 检验单号, m.TEST_NAME AS 检验项目, r.RESULT_DATE_TIME AS 结果时间, i.ITEM_NAME AS 报告项目名称, r.RESULT_VALUE AS 结果值, r.UNITS AS 单位, r.ABNORMAL_INDICATOR AS 异常标记, r.REFERENCE_RANGE AS 参考范围 FROM LAB_TEST_MASTER m JOIN LAB_TEST_ITEMS i ON m.TEST_NO = i.TEST_NO JOIN LAB_RESULT r ON i.ITEM_ID = r.ITEM_ID WHERE {dept_filter} AND TO_CHAR(r.RESULT_DATE_TIME, 'yyyy-mm-dd') = :query_date",
          "field_mapping": {
            "patient_id": "患者ID",
            "visit_number": "次数",
            "test_no": "检验单号",
            "test_name": "检验项目",
            "result_time": "结果时间",
            "item_name": "报告项目名称",
            "report_item_name": "报告项目名称",
            "result": "结果值",
            "units": "单位",
            "abnormal_indicator": "异常标记",
            "reference_range": "参考范围"
          },
          "required": true
        },
        "exam": {
          "type": "sql",
          "query_sql": "SELECT e.PATIENT_ID AS 患者ID, e.VISIT_NUMBER AS 次数, e.EXAM_NO AS 检查号, e.EXAM_DATE_TIME AS 检查时间, r.REPORT_DATE_TIME AS 报告时间, e.EXAM_CLASS AS 检查类别, e.EXAM_NAME AS 检查名称, r.REPORT_TEXT AS 报告内容, r.IMPRESSION AS 影像印象 FROM EXAM_MASTER e JOIN EXAM_REPORT r ON e.EXAM_NO = r.EXAM_NO WHERE {dept_filter} AND TO_CHAR(e.EXAM_DATE_TIME, 'yyyy-mm-dd') = :query_date",
          "field_mapping": {
            "patient_id": "患者ID",
            "visit_number": "次数",
            "exam_no": "检查号",
            "exam_time": "检查时间",
            "report_time": "报告时间",
            "exam_class": "检查类别",
            "exam_name": "检查名称",
