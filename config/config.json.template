    {
      "code": "jyjc_vs_bcnursing",
      "name": "检验检查 vs 病程护理(多源)",
      "description": "检验/检查异常与病程、护理记录一致性核查（多源fanout加载）",
      "enabled": false,
      "sort_order": 25,
      "default_for_schedule": false,
      "sources": {
        "lab": {
          "type": "sql",
          "query_sql": "SELECT m.PATIENT_ID AS 患者ID, m.VISIT_NUMBER AS 次数, m.TEST_NO AS 检验单号, m.TEST_NAME AS 检验项目, r.RESULT_DATE_TIME AS 结果时间, i.ITEM_NAME AS 报告项目名称, r.RESULT_VALUE AS 结果值, r.UNITS AS 单位, r.ABNORMAL_INDICATOR AS 异常标记, r.REFERENCE_RANGE AS 参考范围 FROM LAB_TEST_MASTER m JOIN LAB_TEST_ITEMS i ON m.TEST_NO = i.TEST_NO JOIN LAB_RESULT r ON i.ITEM_ID = r.ITEM_ID WHERE {dept_filter} AND TO_CHAR(r.RESULT_DATE_TIME, 'yyyy-mm-dd') = :query_date",
          "field_mapping": {
            "patient_id": "患者ID",
            "visit_number": "次数",
            "test_no": "检验单号",
            "test_name": "检验项目",
            "result_time": "结果时间",
            "item_name": "报告项目名称",
            "report_item_name": "报告项目名称",
            "result": "结果值",
            "units": "单位",
            "abnormal_indicator": "异常标记",
            "reference_range": "参考范围"
          },
          "required": true
        },
        "exam": {
          "type": "sql",
          "query_sql": "SELECT e.PATIENT_ID AS 患者ID, e.VISIT_NUMBER AS 次数, e.EXAM_NO AS 检查号, e.EXAM_DATE_TIME AS 检查时间, r.REPORT_DATE_TIME AS 报告时间, e.EXAM_CLASS AS 检查类别, e.EXAM_NAME AS 检查名称, r.REPORT_TEXT AS 报告内容, r.IMPRESSION AS 影像印象 FROM EXAM_MASTER e JOIN EXAM_REPORT r ON e.EXAM_NO = r.EXAM_NO WHERE {dept_filter} AND TO_CHAR(e.EXAM_DATE_TIME, 'yyyy-mm-dd') = :query_date",
          "field_mapping": {
            "patient_id": "患者ID",
            "visit_number": "次数",
            "exam_no": "检查号",
            "exam_time": "检查时间",
            "report_time": "报告时间",
            "exam_class": "检查类别",
            "exam_name": "检查名称",
            "description": "报告内容",
            "impression": "影像印象"
          },
          "required": true
        },
        "progress": {
          "type": "sql",
          "query_sql": "SELECT b.患者ID, b.次数, b.病历标题时间 AS 病程时间, b.病历名称 AS 病历名称, b.病历内容 AS 病历内容 FROM jhemr.bcjl202603 b WHERE {dept_filter} AND TO_CHAR(b.病历标题时间, 'yyyy-mm-dd') = :query_date",
          "field_mapping": {
            "patient_id": "患者ID",
            "visit_number": "次数",
            "event_time": "病程时间",
            "record_name": "病历名称",
            "content": "病历内容"
          },
          "required": true
        },
        "nursing": {
          "type": "sql",
          "load_strategy": "fanout",
          "fanout_max_workers": 4,
          "fanout_max_records_per_bundle": 200,
          "fanout_bundle_timeout_seconds": 30,
          "fanout_date_window_days": 61,
          "query_sql": "WITH active_pat AS ( SELECT /*+ MATERIALIZE INDEX(d IDX_INPATIENTS_01) */ d.pat_index_no, d.patient_id FROM ydhl.inpatients d WHERE d.patient_id = :patient_key AND d.dept_code NOT IN ('030210','030224','030603','030611','0306','040711','040712','040705') ), valid_form AS ( SELECT /*+ MATERIALIZE LEADING(p a) USE_NL(a) INDEX(a IDX_MCS_DOC_FORM_01) */ a.id AS form_id, a.patient_uid, a.bed_no, a.form_time, a.created_name, a.created_date FROM active_pat p JOIN ydhl.mcs_doc_form a ON a.patient_uid = p.pat_index_no WHERE a.is_valid = '1' AND a.form_time >= TO_DATE(:date_from, 'yyyy-mm-dd') AND a.form_time < TO_DATE(:date_to, 'yyyy-mm-dd') + 1 ), base AS ( SELECT /*+ LEADING(f c n) USE_NL(c) INDEX(c IDX_MCS_DOC_FORM_RECORDS_01) USE_NL(n) */ p.patient_id AS patient_id, f.patient_uid AS patient_uid, f.bed_no AS bed_no, f.form_time AS nursing_form_created_at, f.created_name AS recorder_name, f.created_date AS nursing_time, f.form_id AS form_id, c.template_code, c.node_code AS code, CASE WHEN c.string_value IS NOT NULL THEN c.string_value WHEN c.number_value = 1 THEN NVL(n.display_name, n.name) WHEN c.number_value IS NOT NULL THEN TRIM(TO_CHAR(c.number_value, 'FM99999999990.099')) END AS value, ROW_NUMBER() OVER (PARTITION BY f.form_id, c.node_code ORDER BY n.id) AS rn FROM valid_form f JOIN active_pat p ON p.pat_index_no = f.patient_uid JOIN ydhl.mcs_doc_form_records c ON c.form_id = f.form_id AND c.template_code IN ('572','709') AND c.node_code IN ('00172','00174','00122','00120','00093','00094','00022','00023','00024','00029','00153','00062') AND (c.string_value IS NOT NULL OR c.number_value IS NOT NULL) LEFT JOIN ydhl.mcs_doc_nodes n ON n.template_code = c.template_code AND n.code = c.node_code ) SELECT base.patient_id AS \"护理患者ID\", base.patient_uid AS \"患者UID\", base.bed_no AS \"床号\", base.form_id AS \"FORM_ID\", base.nursing_time AS event_time, base.recorder_name AS \"记录人\", base.nursing_form_created_at AS \"护理记录表单单创建时间\", base.template_code AS \"TEMPLATE_CODE\", CASE base.template_code WHEN '572' THEN '一般患者护理记录单' WHEN '709' THEN '病重（病危）患者护理记录' ELSE '其他' END AS record_name, COALESCE(MAX(CASE WHEN base.template_code = '572' AND base.code = '00172' THEN base.value END), MAX(CASE WHEN base.template_code = '709' AND base.code = '00022' THEN base.value END)) AS \"体温\", COALESCE(MAX(CASE WHEN base.template_code = '572' AND base.code = '00174' THEN base.value END), MAX(CASE WHEN base.template_code = '709' AND base.code = '00023' THEN base.value END)) AS \"心率脉搏\", COALESCE(MAX(CASE WHEN base.template_code = '572' AND base.code = '00122' THEN base.value END), MAX(CASE WHEN base.template_code = '709' AND base.code = '00024' THEN base.value END)) AS \"呼吸\", COALESCE(MAX(CASE WHEN base.template_code = '572' AND base.code = '00120' THEN base.value END), MAX(CASE WHEN base.template_code = '709' AND base.code = '00029' THEN base.value END)) AS \"血氧饱和度\", COALESCE(MAX(CASE WHEN base.template_code = '572' AND base.code = '00093' THEN base.value END), MAX(CASE WHEN base.template_code = '709' AND base.code = '00153' THEN base.value END)) AS content, COALESCE(MAX(CASE WHEN base.template_code = '572' AND base.code = '00094' THEN base.value END), MAX(CASE WHEN base.template_code = '709' AND base.code = '00062' THEN base.value END)) AS \"护士签名\" FROM base WHERE base.rn = 1 GROUP BY base.patient_id, base.patient_uid, base.bed_no, base.form_id, base.nursing_form_created_at, base.recorder_name, base.nursing_time, base.template_code HAVING COALESCE(MAX(CASE WHEN base.template_code = '572' AND base.code = '00093' THEN base.value END), MAX(CASE WHEN base.template_code = '709' AND base.code = '00153' THEN base.value END)) IS NOT NULL ORDER BY base.nursing_time",
          "field_mapping": {
            "patient_id": "患者ID",
            "visit_number": "次数",
            "event_time": "EVENT_TIME",
            "record_name": "RECORD_NAME",
            "content": "CONTENT"
          },
          "required": true
        }
      },
