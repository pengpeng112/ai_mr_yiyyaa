# Med-Audit 环境变量示例
# 复制为 .env 后按实际环境修改。生产环境请替换所有示例值。

# JWT 签名密钥，建议使用随机 32+ 位字符串
JWT_SECRET_KEY=replace-with-random-jwt-secret

# 配置加密密钥，用于加解密 config.json 中的 password_enc / api_key_enc
SECRET_KEY=replace-with-random-secret-key

# 运行环境：development / production
ENVIRONMENT=development

# 允许访问前端地址，多个来源可用逗号分隔
ALLOWED_ORIGINS=http://localhost:8000

# 应用数据库类型：sqlite / oracle
APP_DB_TYPE=sqlite

# Oracle 连接示例值：首次部署可保留示例地址，接入真实 Oracle 前请改为实际地址
APP_ORACLE_HOST=10.255.255.20
APP_ORACLE_PORT=1521
APP_ORACLE_SERVICE_NAME=orcl
APP_ORACLE_USERNAME=
APP_ORACLE_PASSWORD=

# 演示模式：true 时允许演示/样例能力，生产建议关闭
DEMO_MODE=false

# 可选：指定配置模板路径；未设置时默认使用 config/config.json.template
CONFIG_TEMPLATE_PATH=config/config.json.template

# 可选：部署服务器调试连接信息（不要在项目文件中保存密码）
DEPLOY_SSH_HOST=10.10.8.84
DEPLOY_SSH_PORT=40022
DEPLOY_SSH_USER=root
