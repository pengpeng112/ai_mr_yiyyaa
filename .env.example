# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production-12345
SECRET_KEY=your-app-secret-key-change-in-production-12345
# 建议用以下命令生成高强度随机密钥：
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# 数据库配置
DB_PATH=data/audit.db
DATA_DIR=data
APP_DB_TYPE=sqlite
APP_ORACLE_HOST=10.255.255.20
APP_ORACLE_PORT=1521
APP_ORACLE_SERVICE_NAME=orcl
APP_ORACLE_USERNAME=
APP_ORACLE_PASSWORD=

# CORS 配置
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080

# 日志配置
LOG_DIR=logs
ENVIRONMENT=development

# 调度器配置
# 如需将调度器拆到独立进程，可在 Web 实例上设为 false
ENABLE_SCHEDULER=true

# Oracle 配置（可选）
ORACLE_HOST=10.255.255.20
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=orcl

# Dify 配置（可选）
DIFY_BASE_URL=http://10.255.255.10/v1
DIFY_API_KEY=your-dify-api-key
